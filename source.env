# Source-page config for the Oslo kommune eiendomsoversikt sync workflow.
# Edit this file (not the workflow YAML) when the kommune restructures the page.
#
# Why externalised: the kommune migrated their CMS between April 2025 and May
# 2026 — /getfile.php/<id>-<unix-timestamp>/… became /get-file/<id>/<sha-hex>.
# The page URL itself survived the migration; the anchor text "(XLSX)" also
# survived. If either ever moves, the fix lives here, not in the workflow.

SOURCE_HOST="https://www.oslo.kommune.no"
SOURCE_PAGE_PATH="/plan-bygg-og-eiendom/kart-og-eiendomsinformasjon/kommunal-eiendom/eiendomsoversikt/"

# Anchor-text substring that uniquely identifies the XLSX download link.
# Disambiguates from the sibling PDF link on the same page.
# Must be quoted — bare parens would parse as a shell array literal on `source`.
XLSX_LINK_MARKER="(XLSX)"

# ---- geocode.py runtime config ----
# Loaded by geocode.py via a tiny built-in dotenv reader, so local runs of
# `poetry run python geocode.py …` pick up these settings without needing a
# shell `source` first. Env vars already set in the shell win over this file.

# Norwegian kommune code (KNR). Always 4-digit, zero-padded.
#   0301  Oslo (default — this project's target)
#   4601  Bergen
#   5001  Trondheim
KOMMUNE="0301"

# Comma-separated list of owning agencies to include. Empty string = the full
# register (~7,000 properties). Trailing/leading whitespace per item is
# stripped on parse so values can be written either tight or spaced.
#   ""                                                                 (all four — current default)
#   "Boligbygg Oslo KF"                                                (housing only)
#   "Boligbygg Oslo KF,Oslobygg KF"                                    (housing + public buildings + care homes)
#   "Eiendoms- og byfornyelsesetaten,Oslobygg KF,Boligbygg Oslo KF,Oslo Havn KF"  (explicitly all)
INCLUDE_EIER=""

# Source-page config for the Oslo kommune eiendomsoversikt sync workflow.
# Edit this file (not the workflow YAML) when the kommune restructures the page.
#
# Why externalised: the kommune migrated their CMS between April 2025 and May
# 2026 — /getfile.php/<id>-<unix-timestamp>/… became /get-file/<id>/<sha-hex>.
# The page URL itself survived the migration; the anchor text "(XLSX)" also
# survived. If either ever moves, the fix lives here, not in the workflow.

SOURCE_HOST="https://www.oslo.kommune.no"
SOURCE_PAGE_PATH="/plan-bygg-og-eiendom/kart-og-eiendomsinformasjon/kommunal-eiendom/eiendomsoversikt/"

# Anchor-text substring that uniquely identifies the XLSX download link.
# Disambiguates from the sibling PDF link on the same page.
# Must be quoted — bare parens would parse as a shell array literal on `source`.
XLSX_LINK_MARKER="(XLSX)"
